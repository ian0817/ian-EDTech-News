{
  "builds": [
    { "src": "server.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/(.*)", "dest": "server.js" }
  ],
  "crons": [
    {
      "path": "/api/cron/editorial",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/microlearn",
      "schedule": "0 22 * * *"
    },
    {
      "path": "/api/cron/conferences",
      "schedule": "0 17 * * *"
    }
  ]
}
